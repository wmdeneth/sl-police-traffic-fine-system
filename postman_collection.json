{
  "info": {
    "name": "SL Police Traffic Fine System",
    "description": "Postman collection for Sri Lanka Police Traffic Fine Payment System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" },
    { "key": "referenceNo", "value": "TF-ABC123" },
    { "key": "categoryId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@police.lk\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login (Officer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"officer@police.lk\",\n  \"password\": \"officer123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },
    {
      "name": "Fines",
      "item": [
        {
          "name": "Issue Fine (Officer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var json = pm.response.json();",
                  "  if (json.data) {",
                  "    pm.collectionVariables.set('referenceNo', json.data.referenceNo);",
                  "    pm.collectionVariables.set('categoryId', json.data.categoryId);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{categoryId}}\",\n  \"driverName\": \"John Doe\",\n  \"vehicleNo\": \"ABC-1234\",\n  \"district\": \"Colombo\"\n}"
            },
            "url": "{{baseUrl}}/fines"
          }
        },
        {
          "name": "Lookup Fine by Reference",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/fines/{{referenceNo}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Process Payment (Web)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referenceNo\": \"{{referenceNo}}\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"paymentMethod\": \"CARD\",\n  \"channel\": \"WEB\",\n  \"cardHolderName\": \"John Doe\"\n}"
            },
            "url": "{{baseUrl}}/payments"
          }
        },
        {
          "name": "Process Payment (App)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referenceNo\": \"{{referenceNo}}\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"paymentMethod\": \"CARD\",\n  \"channel\": \"APP\",\n  \"cardHolderName\": \"John Doe\"\n}"
            },
            "url": "{{baseUrl}}/payments"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/summary"
          }
        },
        {
          "name": "District Collections",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/collections/district"
          }
        },
        {
          "name": "Category Collections",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/collections/category"
          }
        }
      ]
    }
  ]
}
