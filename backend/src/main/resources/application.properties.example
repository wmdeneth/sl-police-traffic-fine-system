server.port=${SERVER_PORT:8080}
spring.profiles.active=${SPRING_PROFILES_ACTIVE:local}

# Local profile starts with an in-memory H2 database.
# To use Supabase, set SPRING_PROFILES_ACTIVE=supabase and provide:
# DATABASE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=<supabase-password>

jwt.secret=${JWT_SECRET:replace-with-a-256-bit-secret}
jwt.expiration=${JWT_EXPIRATION:86400000}

notify.lk.user-id=${NOTIFY_LK_USER_ID:}
notify.lk.api-key=${NOTIFY_LK_API_KEY:}
notify.lk.notify-id=${NOTIFY_LK_NOTIFY_ID:NotifyDEMO}

# Public URL used inside QR codes generated when an officer issues a fine.
app.payment-web-base-url=${PAYMENT_WEB_BASE_URL:http://localhost:3000}
